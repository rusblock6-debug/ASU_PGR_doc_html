# API ключ для доступа к AI боту
API_KEY=change-me-in-production

# Настройки Ollama
OLLAMA_MODEL=phi4-mini
OLLAMA_URL=http://ollama:11434

# Настройки Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Настройки ChromaDB
CHROMA_PERSIST_DIR=/app/chroma_data

# Порт AI бота
AI_BOT_PORT=8000

# Порт сервера документации
DOCS_SERVER_PORT=3000
