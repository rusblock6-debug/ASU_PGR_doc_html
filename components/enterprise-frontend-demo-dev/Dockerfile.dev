# Development Dockerfile with hot reload
FROM dockerhub.timeweb.cloud/node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

# Expose Vite dev server port
EXPOSE 3000

# Ensure dependencies are installed after mounting volumes, then start dev server
CMD ["sh", "-c", "npm install && npm run dev -- --host 0.0.0.0"]

