# Transport library
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_SEC=1.0
RABBIT_TRANSPORT_USER=transport_service
RABBIT_TRANSPORT_PASSWORD=transport_service

# Адрес серверного Enterprise Service для синхронизации (Bort -> Server)
# Имя переменной совпадает с ожидаемым в enterprise-service (config.py)
SERVER_SYNC_BASE_URL=http://host.docker.internal:8002

# Sync Service Bort Configuration
SYNC_SERVICE_PORT=8007
SYNC_SERVICE_INSTANCE_ID=bort_4
SYNC_SERVICE_SERVER_INSTANCE_ID=server
SYNC_SERVICE_MODE=dev
SYNC_SERVICE_LOG_LEVEL=DEBUG
SYNC_SERVICE_DEBUG_MODE=1
SYNC_SERVICE_REDIS_URL=redis://redis:6379/1
SYNC_SERVICE_MQTT_BROKER_HOST=nanomq
SYNC_SERVICE_MQTT_BROKER_PORT=1883
SYNC_SERVICE_AUTOREPUB_MQTT_BROKER_HOST=nanomq
SYNC_SERVICE_AUTOREPUB_MQTT_BROKER_PORT=1883
SYNC_SERVICE_RABBITMQ_DSN=amqp://sync_service_user:sync_service_pass@rabbitmq:5672/

# Frontend
VITE_API_URL=http://localhost:8000
