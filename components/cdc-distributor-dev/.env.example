RABBIT_HOST=localhost
RABBIT_PORT=5552
RABBIT_USER=guest
RABBIT_PASSWORD=guest
RABBIT_VHOST=/

# Retry settings (optional, defaults provided)
RETRY_MAX_RETRIES=5
RETRY_INITIAL_DELAY=1.0
RETRY_MAX_DELAY=60.0
RETRY_EXPONENTIAL_BASE=2.0
RETRY_JITTER=true

#RabbitMQ AMQP settings
RABBIT_AMQP_HOST=localhost
RABBIT_AMQP_PORT=5672
RABBIT_AMQP_USER=guest
RABBIT_AMQP_PASSWORD=guest

# Fan-out bort configuration
BORT_IDS=1,2,3

# Distributor DB for per-bort offset tracking
DISTRIBUTOR__POSTGRES_HOST=localhost
DISTRIBUTOR__POSTGRES_PORT=5432
DISTRIBUTOR__POSTGRES_USER=postgres
DISTRIBUTOR__POSTGRES_PASSWORD=postgres
DISTRIBUTOR__POSTGRES_DATABASE=distributor
