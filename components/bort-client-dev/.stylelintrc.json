{
  "extends": ["stylelint-config-standard", "stylelint-config-recess-order", "stylelint-config-css-modules"],
  "plugins": ["stylelint-declaration-strict-value"],
  "rules": {
    "scale-unlimited/declaration-strict-value": [
      [
        "/color$/",
        "fill",
        "stroke",
        "font-size",
        "font-family",
        "font-weight",
        "z-index",
        "background-color",
        "background",
        "border-color"
      ],
      {
        "ignoreValues": ["currentColor", "currentcolor", "transparent", "inherit", "initial", "unset", "none", "0"],
        "ignoreKeywords": ["composes"]
      }
    ],
    "custom-property-pattern": [
      "^([a-z][a-z0-9]*)(-[a-z0-9]+)*$",
      {
        "message": "CSS переменные должны быть в kebab-case: --color-primary"
      }
    ],
    "color-hex-length": "long",
    "color-named": "never",
    "font-weight-notation": "numeric",
    "unit-disallowed-list": [
      ["pt", "cm", "mm", "in", "pc"],
      {
        "message": "Используйте относительные единицы: px, rem, em, %, vh, vw"
      }
    ],
    "value-no-vendor-prefix": true,
    "property-no-vendor-prefix": true,
    "declaration-no-important": true,
    "selector-max-id": 0,
    "selector-max-universal": 1,
    "selector-max-type": [
      2,
      {
        "ignore": ["child", "descendant", "compounded"]
      }
    ],
    "selector-max-class": 4,
    "selector-max-combinators": 3,
    "selector-no-qualifying-type": [
      true,
      {
        "ignore": ["attribute", "class"]
      }
    ],
    "selector-no-vendor-prefix": true,
    "media-feature-name-no-vendor-prefix": true,
    "max-nesting-depth": [
      3,
      {
        "ignore": ["blockless-at-rules", "pseudo-classes"]
      }
    ],
    "no-descending-specificity": null,
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["mixin", "define-mixin", "mixin-content"]
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.module.css"],
      "rules": {
        "selector-class-pattern": [
          "^[a-z][a-z0-9_-]*$",
          {
            "message": "Используйте BEM-подобное именование: .block, .block_element, .block-element"
          }
        ]
      }
    },
    {
      "files": ["**/mixins/**/*.css"],
      "rules": {
        "media-feature-range-notation": null,
        "media-query-no-invalid": null
      }
    }
  ]
}
