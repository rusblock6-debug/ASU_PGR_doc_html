# Базовый URL API (в dev оставьте пустым — запросы идут на Vite proxy /api)
VITE_API_URL=

# Trip Service для vite proxy (целевой хост бэкенда)
VITE_TRIP_SERVICE_URL=http://10.100.109.15:8000

# ID техники для activate/cancel и фильтров
VITE_VEHICLE_ID=17

# Graph Service для vite proxy (место и тип груза)
VITE_GRAPH_SERVICE_URL=http://10.100.109.15:5001

# Базовый URL Graph API (в dev пусто — `/graph-api` через Vite proxy). RTK graphApi + SSE route stream.
VITE_GRAPH_API_URL=

# Enterprise Service для vite proxy (плотность груза)
VITE_ENTERPRISE_SERVICE_URL=http://10.100.109.15:8002

# Fallback шапки kiosk (имя ТС с enterprise GET /api/vehicles/:id по VITE_VEHICLE_ID; ФИО — из мок-сессии)
VITE_KIOSK_VEHICLE_LABEL=Техника
VITE_KIOSK_DRIVER_NAME=—
