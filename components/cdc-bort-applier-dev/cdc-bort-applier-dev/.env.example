# CDC Bort Applier — environment configuration
# Copy to .env and fill in values for your deployment

# Bort (vehicle) identifier — used in queue names: server.bort_{BORT_ID}.cdc_{service}.dst
BORT_ID=4

# AMQP connection (separate fields, computed into AMQP_URL)
AMQP_HOST=localhost
AMQP_PORT=5672
AMQP_USER=guest
AMQP_PASSWORD=guest
AMQP_VHOST=/

# Retry settings (optional, defaults provided)
RETRY__MAX_RETRIES=5
RETRY__INITIAL_DELAY=1.0
RETRY__MAX_DELAY=60.0
RETRY__EXPONENTIAL_BASE=2.0
RETRY__JITTER=true

# Per-service PostgreSQL settings (use __ delimiter for nested config)
# Uncomment and set the services your bort instance runs

# GraphServiceDB
GRAPH_SERVICE__POSTGRES_DATABASE=dump_service
GRAPH_SERVICE__POSTGRES_USER=postgres
GRAPH_SERVICE__POSTGRES_PASSWORD=postgres
GRAPH_SERVICE__POSTGRES_HOST=localhost
GRAPH_SERVICE__POSTGRES_PORT=5432

# EnterpriseServiceDB
# ENTERPRISE_SERVICE__POSTGRES_DATABASE=enterprise
# ENTERPRISE_SERVICE__POSTGRES_USER=postgres
# ENTERPRISE_SERVICE__POSTGRES_PASSWORD=postgres
# ENTERPRISE_SERVICE__POSTGRES_HOST=localhost
# ENTERPRISE_SERVICE__POSTGRES_PORT=5432

# AuthServiceDB
# AUTH_SERVICE__POSTGRES_DATABASE=auth
# AUTH_SERVICE__POSTGRES_USER=postgres
# AUTH_SERVICE__POSTGRES_PASSWORD=postgres
# AUTH_SERVICE__POSTGRES_HOST=localhost
